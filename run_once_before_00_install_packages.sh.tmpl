#!/bin/sh
set -e

{{ if eq .chezmoi.os "darwin" -}}
# === macOS: Install via Homebrew ===
if ! command -v brew >/dev/null; then
  echo "Installing Homebrew..."
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/master/install.sh)"
  if [ -x /opt/homebrew/bin/brew ]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
  elif [ -x /usr/local/bin/brew ]; then
    eval "$(/usr/local/bin/brew shellenv)"
  fi
fi

echo "Installing Brew Packages..."
brew install git tig bit-git curl asdf zsh coreutils gemini-cli neovim ripgrep fd gcc tree-sitter-cli

# Install gemini-cli superpowers extension
if command -v gemini >/dev/null; then
  echo "Installing gemini-cli superpowers extension..."
  gemini extensions install https://github.com/obra/superpowers || true
fi

# ASDF Setup (macOS)
if [ -f "$(brew --prefix asdf)/libexec/asdf.sh" ]; then
    . "$(brew --prefix asdf)/libexec/asdf.sh"
elif [ -f "$(brew --prefix asdf)/asdf.sh" ]; then
    . "$(brew --prefix asdf)/asdf.sh"
fi
export PATH="${ASDF_DATA_DIR:-$HOME/.asdf}/shims:$PATH"

asdf plugin add golang || true
asdf plugin add terraform || true

if [ -f "$HOME/.tool-versions" ]; then
    echo "Installing ASDF versions..."
    asdf install
fi

{{ else -}}
# === Linux (Ubuntu 22.04): Online Install ===

if command -v apt-get >/dev/null; then
  echo "Installing core packages via apt..."
  sudo apt-get update -qq
  sudo apt-get install -y zsh tmux git curl wget unzip build-essential fd-find bat eza
fi

# --- Install asdf ---
if ! command -v asdf >/dev/null; then
  if command -v git >/dev/null; then
    echo "Installing asdf from GitHub..."
    ASDF_VERSION=$(curl -fsS https://api.github.com/repos/asdf-vm/asdf/releases/latest \
      | grep '"tag_name"' | cut -d'"' -f4)
    git clone --depth=1 --branch "${ASDF_VERSION}" \
      https://github.com/asdf-vm/asdf.git "$HOME/.asdf"
  fi
fi

{{ end -}}
