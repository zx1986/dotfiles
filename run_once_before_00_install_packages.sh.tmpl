#!/bin/sh
set -e

{{ if eq .chezmoi.os "darwin" -}}
# === macOS: Install via Homebrew ===
if ! command -v brew >/dev/null; then
  echo "Installing Homebrew..."
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/master/install.sh)"
  if [ -x /opt/homebrew/bin/brew ]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
  elif [ -x /usr/local/bin/brew ]; then
    eval "$(/usr/local/bin/brew shellenv)"
  fi
fi

echo "Installing Brew Packages..."
brew install git tig bit-git curl asdf zsh coreutils gemini-cli neovim ripgrep fd gcc

# Install gemini-cli superpowers extension
if command -v gemini >/dev/null; then
  echo "Installing gemini-cli superpowers extension..."
  gemini extensions install https://github.com/obra/superpowers || true
fi

# ASDF Setup (macOS)
if [ -f "$(brew --prefix asdf)/libexec/asdf.sh" ]; then
    . "$(brew --prefix asdf)/libexec/asdf.sh"
elif [ -f "$(brew --prefix asdf)/asdf.sh" ]; then
    . "$(brew --prefix asdf)/asdf.sh"
fi

{{ else -}}
# === Linux (Ubuntu 22.04): Online Install ===

{{- if not .is_offline }}
if command -v apt-get >/dev/null; then
  echo "Installing core packages via apt..."
  sudo apt-get update -qq
  # Added packages for parity with macOS and to pass verification
  sudo apt-get install -y zsh tmux git curl wget unzip build-essential fd-find bat fzf tig ripgrep
fi

# --- Install asdf ---
if ! command -v asdf >/dev/null && [ ! -d "$HOME/.asdf" ]; then
  if command -v git >/dev/null; then
    echo "Installing asdf from GitHub..."
    ASDF_VERSION=$(curl -fsS https://api.github.com/repos/asdf-vm/asdf/releases/latest \
      | grep '"tag_name"' | cut -d'"' -f4)
    # Fallback if API rate limit is hit
    if [ -z "$ASDF_VERSION" ]; then
      ASDF_VERSION="v0.14.0" 
    fi
    git clone --depth=1 --branch "${ASDF_VERSION}" \
      https://github.com/asdf-vm/asdf.git "$HOME/.asdf"
  fi
fi

# ASDF Setup (Linux)
if [ -f "$HOME/.asdf/asdf.sh" ]; then
    . "$HOME/.asdf/asdf.sh"
fi
{{- else }}
echo "Offline mode detected. Skipping internet-dependent installations (asdf, etc.)."
{{- end }}

{{ end -}}

# === Common ASDF Installation ===
{{- if not .is_offline }}
export PATH="${ASDF_DATA_DIR:-$HOME/.asdf}/shims:$PATH"

if command -v asdf >/dev/null; then
  asdf plugin add golang || true
  asdf plugin add terraform || true

  if [ -f "$HOME/.tool-versions" ]; then
      echo "Installing ASDF versions..."
      asdf install
  fi
fi
{{- end }}
